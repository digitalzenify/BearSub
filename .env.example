# BearSub Configuration

# Server
HOST=0.0.0.0
PORT=8765

# Database
DB_PATH=./data/db/subtitles.db

# File storage
SUBS_DIR=./data/subs

# API Security (optional - leave empty to disable auth)
API_KEY=

# OMDb (for poster/metadata enrichment - optional)
OMDB_API_KEY=

# Force users to enter API key in the web UI
FORCE_ENTER_KEYS=false

# Bazarr Sync (optional)
BAZARR_SYNC_ENABLED=false
BAZARR_URL=http://localhost:6767
BAZARR_API_KEY=your_bazarr_api_key
BAZARR_SYNC_INTERVAL_HOURS=6

# Media root directory (where Bazarr stores subtitle files, read-only mount in Docker)
MEDIA_ROOT_DIR=/path/to/media

# Backup directory
BACKUP_DIR=./backups
